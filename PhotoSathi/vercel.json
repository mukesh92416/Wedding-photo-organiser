{
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://photosathi-backend.onrender.com/api/$1" }
  ],
  "env": {
    "VITE_API_URL": "https://photosathi-backend.onrender.com/api"
  }
}
